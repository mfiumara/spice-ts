{
  "name": "@spice-ts/core",
  "version": "0.2.0",
  "description": "TypeScript-native SPICE circuit simulator engine",
  "license": "MIT",
  "author": "Mattia Fiumara",
  "repository": {
    "type": "git",
    "url": "https://github.com/mfiumara/spice-ts.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/mfiumara/spice-ts",
  "keywords": [
    "spice",
    "circuit",
    "simulator",
    "electronics",
    "eda",
    "netlist",
    "typescript",
    "mna",
    "transient",
    "ac-analysis"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "bench": "vitest bench --config vitest.bench.config.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
